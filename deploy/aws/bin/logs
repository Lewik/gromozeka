#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/aws-common"

instance_id="$(terraform_output instance_id)"
tail_lines="${1:-200}"
[[ "$tail_lines" =~ ^[0-9]+$ ]] || {
  echo "Tail line count must be numeric" >&2
  exit 2
}

remote_command="set -a; source /data/gromozeka/runtime/runtime.env; source /data/gromozeka/runtime/deployment.env; set +a; docker compose --project-name gromozeka --file /opt/gromozeka/runtime/compose.yaml logs --tail=$tail_lines"
parameters="$(jq -nc --arg command "$remote_command" '{commands:[$command]}')"
command_id="$(
  aws_cli ssm send-command \
    --instance-ids "$instance_id" \
    --document-name AWS-RunShellScript \
    --parameters "$parameters" \
    --query Command.CommandId \
    --output text
)"

aws_cli ssm wait command-executed \
  --command-id "$command_id" \
  --instance-id "$instance_id"
aws_cli ssm get-command-invocation \
  --command-id "$command_id" \
  --instance-id "$instance_id" \
  --query StandardOutputContent \
  --output text
