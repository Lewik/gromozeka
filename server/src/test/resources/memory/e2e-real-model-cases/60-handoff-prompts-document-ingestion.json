{
  "id": "handoff-prompts-document-ingestion",
  "category": "document_memory",
  "description": "The real agent_memory_handoff prompt pack should be remembered as prompt/workflow guidance.",
  "timeoutSeconds": 3600,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        {
          "filePath": "agent_memory_handoff/03_prompts.md",
          "documentType": "markdown",
          "title": "Memory Handoff Prompt Pack",
          "sourceRef": "agent_memory_handoff/03_prompts.md",
          "forceWrite": true,
          "mode": "memory_e2e_file_path"
        }
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "According to the handoff prompt pack, what does MemoryRouter v3 decide and what does NoteConstructor v2 create? Keep it short.",
          "answerExpectation": {
            "containsAnyGroups": [
              [
                "MemoryRouter"
              ],
              [
                "write mode",
                "memory write",
                "decides the mode",
                "whether/how",
                "whether to run",
                "which mode"
              ],
              [
                "NoteConstructor"
              ],
              [
                "reusable",
                "semantic",
                "note"
              ]
            ]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedContainsAll": [
              "Prompt Pack"
            ],
            "selectedHitsMin": 1
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 1,
    "requiredSources": [
      {
        "textContainsAll": [
          "Prompt Pack",
          "MemoryRouter",
          "NoteConstructor",
          "ClaimExtractor"
        ],
        "allowStructuredExtraction": true,
        "allowRecall": true
      }
    ],
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
          "DIRECTION",
          "DECISION",
          "PLAN",
          "DOC_DIGEST"
        ],
        "statusIn": [
          "ACTIVE"
        ],
        "containsAll": [
          "MemoryRouter"
        ],
        "evidenceSourceSpeakerRoleIn": [
          "EXTERNAL"
        ]
      }
    ],
    "forbiddenActionItems": [
      {
        "containsAll": [
          "agent_memory_handoff/03_prompts.md"
        ]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": [
      "EXTERNAL"
    ]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 2,
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
          "DIRECTION",
          "DECISION",
          "PLAN",
          "DOC_DIGEST"
        ],
        "statusIn": [
          "ACTIVE"
        ],
        "containsAll": [
          "MemoryRouter"
        ],
        "evidenceSourceSpeakerRoleIn": [
          "EXTERNAL"
        ]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": [
      "EXTERNAL"
    ]
  }
}
