{
  "id": "note-consolidation-episode-recall",
  "category": "lesson_memory",
  "description": "A reusable lesson note should be consolidated into durable memory and recalled as prior experience.",
  "timeoutSeconds": 1000,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        "Memory MVP lesson for the NoMemoryVerifier component: Situation: ReadTimeRetrievalPlanner can incorrectly return need_memory=false for ambiguous recall questions. Action: run one short LLM verification call before accepting the no-memory plan; do not use hard-coded substring heuristics. Result: we avoid brittle lexical hacks while still catching recall intent. Lesson: for ambiguous no-memory recall decisions, prefer a cheap model-based verifier over substring matching."
      ]
    }
  ],
  "maintenanceAfterSeeds": ["consolidate_notes"],
  "maintenanceTraceExpectations": [
    {
      "present": true,
      "stageIn": ["NOTE_CONSOLIDATION"],
      "tracesMin": 1,
      "rawClaimCandidatesMin": 1,
      "finalClaimCandidatesMin": 1,
      "materializedClaimsMin": 1,
      "containsAll": ["substring", "Claim candidates"]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "What reusable lesson did we record about ambiguous no-memory recall decisions? Answer with exactly one sentence.",
          "answerExpectation": {
            "containsAnyGroups": [
              ["NoMemoryVerifier", "model-based verifier", "model-based verification", "LLM verification", "verification call", "model check"],
              ["substring", "lexical", "hard-coded"]
            ]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedNotesMin": 1,
            "selectedContainsAll": ["NoMemoryVerifier"],
            "injectedPromptContainsAll": ["Retrieved notes", "substring"],
            "requiredSelectedNotes": [
              {
                "containsAll": ["substring"],
                "evidenceSourceSpeakerRoleIn": ["USER"]
              }
            ]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "runsMin": 2,
    "userSourcesMin": 1,
    "requiredClaims": [
      {
        "containsAll": ["substring"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "requiredRuns": [
      {
        "runTypeIn": ["CONSOLIDATE_NOTES"],
        "statusIn": ["SUCCESS"],
        "containsAll": ["insert_claim"],
        "appliedOpsMin": 1
      }
    ]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "runsMin": 2,
    "userSourcesMin": 2,
    "requiredClaims": [
      {
        "containsAll": ["substring"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "requiredRuns": [
      {
        "runTypeIn": ["CONSOLIDATE_NOTES"],
        "statusIn": ["SUCCESS"],
        "containsAll": ["insert_claim"],
        "appliedOpsMin": 1
      }
    ]
  }
}
