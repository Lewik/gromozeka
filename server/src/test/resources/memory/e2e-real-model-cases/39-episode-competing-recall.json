{
  "id": "episode-competing-recall",
  "category": "lesson_memory",
  "description": "When multiple reusable lessons exist, runtime recall should select the memory matching the named component and lesson, not a nearby memory lesson.",
  "timeoutSeconds": 1200,
  "seedSessions": [
    {
      "id": "seed-no-memory-verifier",
      "turns": [
        "Memory MVP lesson for the NoMemoryVerifier component: Situation: ReadTimeRetrievalPlanner can incorrectly return need_memory=false for ambiguous recall questions. Action: run one short model-based verification call before accepting the no-memory plan; do not use hard-coded substring heuristics. Result: we avoid brittle lexical hacks while still catching recall intent. Lesson: for ambiguous no-memory recall decisions, prefer a cheap model-based verifier over substring matching."
      ]
    },
    {
      "id": "seed-source-hydrator",
      "turns": [
        "Memory MVP lesson for the SourceHydrator component: Situation: factual answers sometimes need raw source evidence after interpreted claims are retrieved. Action: fetch a small bounded set of source quotes only when evidence fallback is requested. Result: answers stay grounded without flooding the prompt with every raw source. Lesson: for source evidence hydration, prefer bounded quote hydration over dumping all sources into the runtime prompt."
      ]
    }
  ],
  "maintenanceAfterSeeds": ["consolidate_notes"],
  "maintenanceTraceExpectations": [
    {
      "present": true,
      "stageIn": ["NOTE_CONSOLIDATION"],
      "tracesMin": 1,
      "rawClaimCandidatesMin": 2,
      "finalClaimCandidatesMin": 2,
      "materializedClaimsMin": 2,
      "containsAll": ["NoMemoryVerifier", "SourceHydrator"]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-target",
      "turns": [
        {
          "text": "What reusable lesson did we record for NoMemoryVerifier about ambiguous no-memory recall decisions? Answer with exactly one sentence.",
          "answerExpectation": {
            "containsAnyGroups": [
              ["NoMemoryVerifier", "no-memory recall", "ambiguous no-memory"],
              ["model-based verifier", "model-based verification", "LLM verification", "verification call", "model check"],
              ["substring", "hard-coded", "lexical"]
            ],
            "containsNone": ["SourceHydrator", "source hydration", "evidence hydration", "source quotes"]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedClaimsMin": 1,
            "selectedClaimsMax": 1,
            "injectedPromptContainsAll": ["Retrieved claims", "NoMemoryVerifier", "no-memory"],
            "injectedPromptContainsNone": ["SourceHydrator", "source evidence hydration"],
            "requiredSelectedClaims": [
              {
                "containsAll": ["NoMemoryVerifier", "no-memory", "verification"],
                "evidenceSourceSpeakerRoleIn": ["USER"]
              }
            ],
            "forbiddenSelectedClaims": [
              {
                "containsAll": ["SourceHydrator", "source", "hydration"]
              }
            ]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 2,
    "runsMin": 3,
    "userSourcesMin": 2,
    "requiredClaims": [
      {
        "containsAll": ["NoMemoryVerifier", "no-memory", "verification"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      },
      {
        "containsAll": ["SourceHydrator", "source", "hydration"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "requiredRuns": [
      {
        "runTypeIn": ["CONSOLIDATE_NOTES"],
        "statusIn": ["SUCCESS"],
        "containsAll": ["insert_claim"],
        "appliedOpsMin": 2
      }
    ]
  },
  "expectedFinal": {
    "activeClaimsMin": 2,
    "runsMin": 3,
    "userSourcesMin": 3,
    "requiredClaims": [
      {
        "containsAll": ["NoMemoryVerifier", "no-memory", "verification"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      },
      {
        "containsAll": ["SourceHydrator", "source", "hydration"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "requiredRuns": [
      {
        "runTypeIn": ["CONSOLIDATE_NOTES"],
        "statusIn": ["SUCCESS"],
        "containsAll": ["insert_claim"],
        "appliedOpsMin": 2
      }
    ]
  }
}
