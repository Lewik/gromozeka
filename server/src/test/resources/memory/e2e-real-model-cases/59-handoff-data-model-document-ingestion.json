{
  "id": "handoff-data-model-document-ingestion",
  "category": "document_memory",
  "description": "The real agent_memory_handoff data-model document should be remembered as typed model guidance.",
  "timeoutSeconds": 3600,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        {
          "filePath": "agent_memory_handoff/02_data_model.md",
          "documentType": "markdown",
          "title": "Memory Handoff Data Model",
          "sourceRef": "agent_memory_handoff/02_data_model.md",
          "forceWrite": true,
          "mode": "memory_e2e_file_path"
        }
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "According to the handoff data model, what is Source and what is Note for? Keep it short.",
          "answerExpectation": {
            "containsAnyGroups": [
              [
                "Source"
              ],
              [
                "evidence",
                "raw source",
                "сырой источник",
                "what was said",
                "what was said/seen"
              ],
              [
                "Note"
              ]
            ]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedContainsAll": [
              "Source"
            ],
            "selectedHitsMin": 1
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 1,
    "requiredSources": [
      {
        "textContainsAll": [
          "Data Model",
          "Source",
          "Entity",
          "PredicateCatalog",
          "Note"
        ],
        "allowStructuredExtraction": true,
        "allowRecall": true
      }
    ],
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
          "DIRECTION",
          "DECISION",
          "PLAN",
          "DOC_DIGEST"
        ],
        "statusIn": [
          "ACTIVE"
        ],
        "containsAll": [
          "Source"
        ],
        "evidenceSourceSpeakerRoleIn": [
          "EXTERNAL"
        ]
      }
    ],
    "forbiddenActionItems": [
      {
        "containsAll": [
          "agent_memory_handoff/02_data_model.md"
        ]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": [
      "EXTERNAL"
    ]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 2,
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
          "DIRECTION",
          "DECISION",
          "PLAN",
          "DOC_DIGEST"
        ],
        "statusIn": [
          "ACTIVE"
        ],
        "containsAll": [
          "Source"
        ],
        "evidenceSourceSpeakerRoleIn": [
          "EXTERNAL"
        ]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": [
      "EXTERNAL"
    ]
  }
}
