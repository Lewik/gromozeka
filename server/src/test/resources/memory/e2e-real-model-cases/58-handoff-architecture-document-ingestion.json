{
  "id": "handoff-architecture-document-ingestion",
  "category": "document_memory",
  "description": "The real agent_memory_handoff architecture document should be digested into durable memory and recalled across sessions.",
  "timeoutSeconds": 3600,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        {
          "filePath": "agent_memory_handoff/01_architecture.md",
          "documentType": "markdown",
          "title": "Memory Handoff Architecture",
          "sourceRef": "agent_memory_handoff/01_architecture.md",
          "forceWrite": true,
          "mode": "memory_e2e_file_path"
        }
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "According to the handoff architecture document, what are the four axes of memory v3? Keep it short.",
          "answerExpectation": {
            "containsAnyGroups": [
              [
                "Representation"
              ],
              [
                "Lifecycle"
              ],
              [
                "Retrieval policy",
                "Retrieval"
              ],
              [
                "Scope and lineage",
                "Scope"
              ]
            ]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedHitsMin": 1,
            "selectedContainsAll": [
              "Representation"
            ]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 1,
    "requiredSources": [
      {
        "textContainsAll": [
          "Цель системы",
          "memory layer"
        ],
        "allowStructuredExtraction": true,
        "allowRecall": true
      },
      {
        "textContainsAll": [
          "Representation",
          "Claim",
          "Note"
        ],
        "allowStructuredExtraction": true,
        "allowRecall": true
      }
    ],
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
          "DIRECTION",
          "DECISION",
          "PLAN",
          "DOC_DIGEST"
        ],
        "statusIn": [
          "ACTIVE"
        ],
        "containsAll": [
          "Representation"
        ],
        "evidenceSourceSpeakerRoleIn": [
          "EXTERNAL"
        ]
      }
    ],
    "forbiddenActionItems": [
      {
        "containsAll": [
          "agent_memory_handoff/01_architecture.md"
        ]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": [
      "EXTERNAL"
    ]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "notesMin": 1,
    "actionItemsMax": 0,
    "sourcesMin": 2,
    "requiredNotes": [
      {
        "typeIn": [
          "CONTEXT",
