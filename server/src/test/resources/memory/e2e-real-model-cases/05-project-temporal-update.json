{
  "id": "project-temporal-update",
  "category": "temporal_reasoning",
  "description": "A dated project update should preserve historical database context while current recall uses the latest dated fact.",
  "timeoutSeconds": 900,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        "For Gromozeka project context: on 2026-01-10, the memory store database used SQLite during the prototype.",
        "Project update: as of 2026-05-03, the Gromozeka memory store database now uses MongoDB instead of SQLite."
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "What database does the Gromozeka memory store currently use? Answer with only the database name.",
          "answerExpectation": {
            "containsAll": ["MongoDB"],
            "containsNone": ["SQLite", "PostgreSQL", "Neo4j"]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedClaimsMin": 1,
            "selectedContainsNone": ["prototype"],
            "selectorSelectedContainsAll": ["SELECT CLAIM", "MongoDB"],
            "selectorRejectedContainsAll": ["REJECT CLAIM", "SQLite", "prototype"],
            "requiredSelectedClaims": [
              {
                "predicateIn": ["primary_storage_backend", "uses_persistence_database"],
                "statusIn": ["ACTIVE"],
                "objectEntityCanonicalNameIn": ["MongoDB"],
                "normalizedContainsAll": ["MongoDB"]
              }
            ],
            "forbiddenSelectedClaims": [
              {
                "objectEntityCanonicalNameIn": ["SQLite"],
                "normalizedContainsAll": ["prototype"]
              }
            ],
            "injectedPromptContainsAll": ["Gromozeka", "MongoDB"],
            "injectedPromptContainsNone": ["prototype"]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 2,
    "activeClaimsMax": 2,
    "userSourcesMin": 2,
    "requiredEntities": [
      {
        "canonicalNameIn": ["MongoDB"],
        "containsAll": ["MongoDB"]
      }
    ],
    "requiredClaims": [
      {
        "predicateIn": ["uses_persistence_database"],
        "predicatePolicyTemporalPolicyIn": ["TIME_SCOPED"],
        "predicatePolicyConflictPolicyIn": ["RANGE_SPLIT"],
        "statusIn": ["ACTIVE"],
        "subjectEntityCanonicalNameIn": ["Gromozeka"],
        "objectEntityCanonicalNameIn": ["SQLite"],
        "normalizedContainsAll": ["SQLite", "prototype"],
        "evidenceQuoteContainsAll": ["2026-01-10"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      },
      {
        "predicateIn": ["primary_storage_backend"],
        "predicatePolicyTemporalPolicyIn": ["STATUS_LIKE"],
        "predicatePolicyConflictPolicyIn": ["REPLACE"],
        "statusIn": ["ACTIVE"],
        "subjectEntityCanonicalNameIn": ["Gromozeka"],
        "objectEntityCanonicalNameIn": ["MongoDB"],
        "normalizedContainsAll": ["MongoDB"],
        "evidenceQuoteContainsAll": ["as of 2026-05-03"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  },
  "expectedFinal": {
    "activeClaimsMin": 2,
    "activeClaimsMax": 2,
    "userSourcesMin": 3,
    "requiredClaims": [
      {
        "predicateIn": ["uses_persistence_database"],
        "predicatePolicyTemporalPolicyIn": ["TIME_SCOPED"],
        "predicatePolicyConflictPolicyIn": ["RANGE_SPLIT"],
        "statusIn": ["ACTIVE"],
        "subjectEntityCanonicalNameIn": ["Gromozeka"],
        "objectEntityCanonicalNameIn": ["SQLite"],
        "normalizedContainsAll": ["SQLite", "prototype"],
        "evidenceQuoteContainsAll": ["2026-01-10"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      },
      {
        "predicateIn": ["primary_storage_backend"],
        "predicatePolicyTemporalPolicyIn": ["STATUS_LIKE"],
        "predicatePolicyConflictPolicyIn": ["REPLACE"],
        "statusIn": ["ACTIVE"],
        "subjectEntityCanonicalNameIn": ["Gromozeka"],
        "objectEntityCanonicalNameIn": ["MongoDB"],
        "normalizedContainsAll": ["MongoDB"],
        "evidenceQuoteContainsAll": ["as of 2026-05-03"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "forbiddenClaims": [
      {
        "statusIn": ["ACTIVE"],
        "containsAll": ["PostgreSQL"]
      },
      {
        "statusIn": ["ACTIVE"],
        "containsAll": ["Neo4j"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  }
}
