{
  "id": "one-off-edit-command-audit-only",
  "category": "command_memory_policy",
  "description": "A one-off current-turn edit command should be audit-only and must not become durable claim, note, task, or profile memory.",
  "timeoutSeconds": 500,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        {
          "text": "Сотредактируй это, я потом посмотрю diff в IDE сам.",
          "memoryWriteTraceExpectation": {
            "routeDecisionIn": ["NOOP"],
            "materializedClaimsMax": 0,
            "materializedNotesMax": 0,
            "materializedTasksMax": 0,
            "rawClaimOpsMax": 0,
            "rawNoteOpsMax": 0,
            "rawTaskOpsMax": 0
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMax": 0,
    "notesMax": 0,
    "tasksMax": 0,
    "profilesMax": 0,
    "userSourcesMin": 1,
    "requiredSources": [
      {
        "roleIn": ["USER"],
        "textContainsAll": ["diff", "IDE"],
        "allowStructuredExtraction": false,
        "allowRecall": false,
        "allowEvidenceHydration": false
      }
    ],
    "forbiddenClaims": [
      {
        "containsAll": ["diff", "IDE"]
      }
    ],
    "forbiddenNotes": [
      {
        "containsAll": ["diff", "IDE"]
      }
    ],
    "forbiddenTasks": [
      {
        "containsAll": ["diff", "IDE"]
      }
    ],
    "forbiddenProfiles": [
      {
        "containsAll": ["diff", "IDE"]
      }
    ]
  },
  "expectedFinal": {
    "activeClaimsMax": 0,
    "notesMax": 0,
    "tasksMax": 0,
    "profilesMax": 0,
    "userSourcesMin": 1,
    "requiredSources": [
      {
        "roleIn": ["USER"],
        "textContainsAll": ["diff", "IDE"],
        "allowStructuredExtraction": false,
        "allowRecall": false,
        "allowEvidenceHydration": false
      }
    ]
  }
}
