{
  "id": "project-fact-cross-session",
  "category": "multi_session_reasoning",
  "description": "A project fact should be stored from one session and recalled from another without becoming a user preference.",
  "timeoutSeconds": 600,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        "For Gromozeka project context: the memory store uses MongoDB."
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "What database does the Gromozeka memory store use? Answer with only the database name.",
          "answerExpectation": {
            "containsAll": ["MongoDB"],
            "containsNone": ["SQLite", "PostgreSQL", "Neo4j"]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedClaimsMin": 1,
            "requiredSelectedClaims": [
              {
                "normalizedContainsAll": ["Gromozeka", "MongoDB"]
              }
            ],
            "injectedPromptContainsAll": ["Gromozeka", "MongoDB"]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "activeClaimsMax": 1,
    "userSourcesMin": 1,
    "requiredEntities": [
      {
        "typeIn": ["PROJECT", "SERVICE"],
        "canonicalNameIn": ["Gromozeka", "Gromozeka memory store"]
      },
      {
        "canonicalNameIn": ["MongoDB"],
        "containsAll": ["MongoDB"]
      }
    ],
    "requiredClaims": [
      {
        "normalizedContainsAll": ["Gromozeka", "MongoDB"],
        "evidenceQuoteContainsAll": ["For Gromozeka project context: the memory store uses MongoDB."],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "forbiddenClaims": [
      {
        "subjectEntityTypeIn": ["USER"],
        "normalizedContainsAll": ["MongoDB"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "activeClaimsMax": 1,
    "userSourcesMin": 2,
    "requiredClaims": [
      {
        "normalizedContainsAll": ["Gromozeka", "MongoDB"],
        "evidenceQuoteContainsAll": ["For Gromozeka project context: the memory store uses MongoDB."],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "forbiddenClaims": [
      {
        "subjectEntityTypeIn": ["USER"],
        "normalizedContainsAll": ["MongoDB"]
      },
      {
        "containsAll": ["SQLite"]
      },
      {
        "containsAll": ["PostgreSQL"]
      },
      {
        "containsAll": ["Neo4j"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  }
}
