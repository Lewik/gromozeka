{
  "id": "anti-preference",
  "category": "preference_following",
  "description": "A negative recommendation preference should be stored and recalled without turning into a positive preference.",
  "timeoutSeconds": 600,
  "seedSessions": [
    {
      "id": "seed-a",
      "turns": [
        "For future recommendations, remember that I do not want BMW cars recommended to me."
      ]
    }
  ],
  "recallSessions": [
    {
      "id": "recall-b",
      "turns": [
        {
          "text": "Which car brand should you avoid recommending to me? Answer with only the brand name.",
          "answerExpectation": {
            "containsAll": ["BMW"],
            "containsNone": ["Toyota", "Honda", "Ford"]
          },
          "memoryTraceExpectation": {
            "needMemory": true,
            "injectedPromptPresent": true,
            "selectedClaimsMin": 1,
            "requiredSelectedClaims": [
              {
                "predicateIn": ["avoids", "dislikes"],
                "objectEntityCanonicalNameIn": ["BMW", "BMW cars"],
                "normalizedContainsAll": ["BMW"]
              }
            ],
            "injectedPromptContainsAll": ["BMW"]
          }
        }
      ]
    }
  ],
  "expectedAfterSeeds": {
    "activeClaimsMin": 1,
    "activeClaimsMax": 1,
    "userSourcesMin": 1,
    "requiredClaims": [
      {
        "subjectEntityTypeIn": ["USER"],
        "containsAll": ["BMW"],
        "evidenceQuoteContainsAll": ["I do not want BMW cars recommended to me"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  },
  "expectedFinal": {
    "activeClaimsMin": 1,
    "activeClaimsMax": 1,
    "userSourcesMin": 2,
    "requiredClaims": [
      {
        "subjectEntityTypeIn": ["USER"],
        "containsAll": ["BMW"],
        "evidenceQuoteContainsAll": ["I do not want BMW cars recommended to me"],
        "evidenceSourceSpeakerRoleIn": ["USER"]
      }
    ],
    "forbiddenClaims": [
      {
        "predicateIn": ["prefers"],
        "subjectEntityTypeIn": ["USER"],
        "normalizedContainsAll": ["BMW"]
      }
    ],
    "allActiveClaimsEvidenceSpeakerRoleIn": ["USER"]
  }
}
